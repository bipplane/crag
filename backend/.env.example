# --- AI Providers ---
GOOGLE_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_key # Required later for OpenAI Whisper Audio Transcription

# --- Relational Database (PostgreSQL) ---
# Used for storing tenant metadata, mapping external IDs, and logging telemetry
DATABASE_URL=postgresql://postgres:password@localhost:5432/crag_db

# --- Vector Database (Pinecone) ---
# Used for data isolation, RAG, and multi-tenant embeddings
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-gcp
PINECONE_INDEX_NAME=crag-course-index

# --- Task Queue (Celery + Redis) ---
# Used for routing asynchronous requests and background document parsing
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Discord Integration ---
# Used for the multi-tenant global bot proxy and webhook endpoint validation
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_public_key
DISCORD_CLIENT_ID=your_discord_client_id

# --- Authentication & LTI 1.3 Interoperability ---
# Used for educator onboarding and Canvas/LMS integration
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
LTI_ISSUER=https://canvas.instructure.com
LTI_CLIENT_ID=your_lms_developer_key